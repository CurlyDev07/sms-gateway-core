APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=laravel
DB_USERNAME=root
DB_PASSWORD=

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DRIVER=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_COOKIE=sms_gateway_core_session
SESSION_LIFETIME=120

MEMCACHED_HOST=127.0.0.1

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=mailhog
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS=null
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_APP_CLUSTER=mt1

MIX_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
MIX_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

CHAT_APP_INBOUND_URL=
CHAT_APP_TIMEOUT=10
CHAT_APP_TENANT_KEY=
CHAT_APP_INBOUND_SECRET=
CHAT_APP_PLATFORM_KEY=
CHAT_APP_PLATFORM_SECRET=
CHAT_APP_PLATFORM_TIMESTAMP_TOLERANCE_SECONDS=300

GATEWAY_OUTBOUND_RETRY_BASE_DELAY_SECONDS=10
GATEWAY_OUTBOUND_RETRY_ALL_FAILURES=true
GATEWAY_OUTBOUND_STALE_LOCK_SECONDS=300

GATEWAY_INBOUND_RELAY_RETRY_MAX_ATTEMPTS=3
GATEWAY_INBOUND_RELAY_RETRY_BASE_DELAY_SECONDS=30
GATEWAY_INBOUND_RELAY_RETRY_MAX_DELAY_SECONDS=300
GATEWAY_INBOUND_RELAY_LOCK_SECONDS=120

GATEWAY_SIM_SELECTION_HYSTERESIS_HOLD_SECONDS=300
GATEWAY_SIM_SELECTION_FAILURE_WINDOW_MINUTES=15
GATEWAY_SIM_SELECTION_FAILURE_HOLD_THRESHOLD=3
GATEWAY_SIM_SELECTION_QUEUE_HOLD_THRESHOLD=100

GATEWAY_RUNTIME_FAILURE_WINDOW_MINUTES=15
GATEWAY_RUNTIME_FAILURE_THRESHOLD=3
GATEWAY_RUNTIME_SUPPRESSION_MINUTES=15

SMS_DRIVER=python
SMS_PYTHON_API_URL=
SMS_PYTHON_API_TOKEN=
SMS_PYTHON_API_SEND_PATH=/send
SMS_PYTHON_API_HEALTH_PATH=/modems/health
SMS_PYTHON_API_DISCOVER_PATH=/modems/discover
SMS_PYTHON_API_TIMEOUT_SECONDS=90
